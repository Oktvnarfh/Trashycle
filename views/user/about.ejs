<%- include('layout/header') %>
<!-- ======= Hero Section ======= -->
<section id="hero">
    <div class="hero-container">
      <h1>Welcome to Trashycle</h1>
      <h2>Solusi Daur Ulang untuk Masa Depan Lebih Hijau</h2>
      <a href="#about" class="btn-get-started scrollto">Mulai</a>
    </div>
  </section><!-- End Hero -->
  <main id="main">
      <!-- ======= Info Section ======= -->
      <section id="info" class="info">
        <div class="container">
            <div class="count-box py-5">
