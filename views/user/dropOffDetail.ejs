<%- include('layout/header') %>
<section class="py-5" style="margin-top: 130px;">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row gx-4 gx-lg-5 align-items-center">
            <div class="col-md-6"><img class="card-img-top mb-5 mb-md-0" src="/uploads/user/<%= location.image %>" alt="<%= location.name %>" /></div>
            <div class="col-md-6">
                <div class="small mb-1">SKU: <%= location.id %></div>
                <h1 class="display-5 fw-bolder"><%= location.name %></h1>
                <div class="info">
                    <address class="location">
                      <i class="bi bi-map fa-sm"></i>
                      <%= location.address %>
                    </address>
                    <div class="city">
                      <i class="fas fa-map-marker-alt fa-sm"></i>
                      <%= location.city %>
                    </div>
                  </div>
                <div class="fs-5 mb-3">
                    <span><%= location.province %></span>
                </div>
                <hr class="mb-4">
                <!-- <p class="lead">Lorem ipsum dolor sit amet consectetur adipisicing elit. Praesentium at dolorem quidem modi. Nam sequi consequatur obcaecati excepturi alias magni, accusamus eius blanditiis delectus ipsam minima ea iste laborum vero?</p> -->
                <div class="d-flex">
                    <button class="btn btn-outline-secondary border-secondary flex-shrink-0 btn-lg rounded-0" type="button">
                        <i class='bx bx-plus'></i>
                        Direct Message
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Description items section -->
<div class="container">
    <div class="row px-xl-5">
        <div class="col">
            <div class="nav nav-tabs justify-content-start border-secondary mb-4">
                <a class="nav-item nav-link active" data-toggle="tab" href="#tab-pane-1">Contact</a>
                <a class="nav-item nav-link" data-toggle="tab" href="#tab-pane-2">Jadwal Operasional</a>
            </div>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-pane-1">
                    <<div class="media">
                        <label>E-mail</label>
                        <p><%= location.email %></p>
                    </div>
                    <div class="media">
                        <label>Phone</label>
                        <p><%= location.phone %></p>
                    </div>
                    <div class="media">
                        <label>Kategori</label>
                        <p><%= location.category_name %></p>
                    </div>
                </div>
                <div class="tab-pane fade" id="tab-pane-3">
                    <div class="row">
                        <div class="col-md-6">
                            <h4 class="mb-4">Leave a review</h4>
                            <small>Your email address will not be published. Required fields are marked *</small>
                            <h4>Jadwal Operasional:</h4>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
  <%- include('layout/footer') %>