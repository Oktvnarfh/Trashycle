<%- include('layout/header') %>
<section class="section about-section gray-bg" id="about">
    <div class="container">
        <div class="row align-items-center flex-row-reverse">
            <div class="col-lg-6">
                <div class="about-text go-to">
                    <h3 class="dark-color"><%= location.name %></h3>
                    <div class="row about-list">
                        <div class="col-md-6">
                            <div class="media">
                                <label>Alamat</label>
                                <p><%= location.address %></p>
                            </div>
                            <div class="media">
                                <label>Provinsi</label>
                                <p><%= location.province %></p>
                            </div>
                            <div class="media">
                                <label>Kota</label>
                                <p><%= location.city %></p>
                            </div>
                            <div class="media">
                                <label>Kode Pos</label>
                                <p><%= location.postcode %></p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="media">
                                <label>E-mail</label>
                                <p><%= location.email %></p>
                            </div>
                            <div class="media">
                                <label>Phone</label>
                                <p><%= location.phone %></p>
                            </div>
                            <div class="media">
                                <label>Kategori</label>
                                <p><%= location.category_name %></p>
                            </div>
                            <div class="media">
                                <label>Tanggal Dibuat</label>
                                <p><%= location.createdAt.toDateString() %></p>
                            </div>
                        </div>
                    </div>
                    <h4>Jadwal Operasional:</h4>
                    <ul>
                        <% location.schedules.forEach(schedule => { %>
                            <li>
                                <strong><%= schedule.day %>:</strong> 
                                <%= schedule.open_time %> - <%= schedule.close_time %>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="about-avatar">
                    <% if (location.image) { %>
                        <img src="/uploads/user/<%= location.image %>" alt="<%= location.name %>" style="max-width: 100%; height: auto;">
                    <% } else { %>
                        <img src="https://bootdey.com/img/Content/avatar/avatar7.png" alt="<%= location.name %>" style="max-width: 100%; height: auto;">
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>
<%- include('layout/footer') %>
